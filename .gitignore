# Virtual environment
.venv/
venv/

# Processed data (large, regenerated from DB) — keep the directory marker
data/processed/*.parquet
# Curated subwindows of the processed data (e.g. AMBER v2 day window
# locked for cross-cohort comparison; force-close-architecture S01).
data/processed_*/*.parquet

# Oracle sample cache (arb-curriculum Session 01) — gitignored, regenerated offline
data/oracle_cache/

# Model weights (large binary files)
registry/weights/

# Secrets
.env
*.env

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.suo
*.user

# Logs
logs/

# SQLite registry (regenerated, not source)
registry/models.db

# Per-run bet logs (now under logs/) and planner JSON files (regenerated by training runs)
logs/bet_logs/
registry/bet_logs/
registry/training_plans/

# Session-tagged model stores / weights / bet logs (Session 9 and
# any future session-scoped training runs). Generated, not source.
registry/session_*.db
registry/session_*_weights/
registry/session_*_bet_logs/

# Jupyter
.ipynb_checkpoints/

# Registry archives — historical run snapshots (weights + dbs, GB-scale)
registry/archive_*/
registry/v2_*/

# Phase-0 scorer artefacts — regenerated by training_v2/scorer/train_and_evaluate
data/scorer_v1/
models/scorer_v1/

# Per-run test artefacts
tests/_evaluate_tmp_data/

# Claude Code runtime / per-machine settings
