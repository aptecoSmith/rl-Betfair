# Virtual environment
.venv/
venv/

# Scratch outputs for side-thread probes (e.g. trajectory-retrieval-probe).
# Throwaway by design — see plans/trajectory-retrieval-probe/hard_constraints.md §7.
scratch/

# Processed data (large, regenerated from DB) — keep the directory marker
data/processed/*.parquet
# Curated subwindows of the processed data (e.g. AMBER v2 day window
# locked for cross-cohort comparison; force-close-architecture S01).
data/processed_*/*.parquet

# Oracle sample cache (arb-curriculum Session 01) — gitignored, regenerated offline
data/oracle_cache/
data/oracle_cache_v2/

# Direction-predictor labels and predictor dataset — regenerated offline
data/direction_labels/
data/predictor_dataset/

# Model weights (large binary files)
registry/weights/

# Secrets
.env
*.env

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.suo
*.user

# Logs
logs/

# SQLite registry (regenerated, not source)
registry/models.db

# Per-run bet logs (now under logs/) and planner JSON files (regenerated by training runs)
logs/bet_logs/
registry/bet_logs/
registry/training_plans/

# Session-tagged model stores / weights / bet logs (Session 9 and
# any future session-scoped training runs). Generated, not source.
registry/session_*.db
registry/session_*_weights/
registry/session_*_bet_logs/

# Jupyter
.ipynb_checkpoints/

# Registry archives — historical run snapshots (weights + dbs, GB-scale)
registry/archive_*/
registry/v2_*/

# Per-cohort training output (registry/_phase*, registry/v2_phase*) — GB-scale
registry/_*/
registry/_*.log
registry/_*.txt
registry/v2_phase*/
registry/v2_phase*.log

# Phase-0 scorer artefacts — regenerated by training_v2/scorer/train_and_evaluate
data/scorer_v1/
models/scorer_v1/

# Per-run test artefacts
tests/_evaluate_tmp_data/

# Claude Code runtime / per-machine settings
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/worktrees/
frontend/.claude/

# --- Plan-local + per-run artefacts (regenerable; not source) — 2026-06-02 ---
# Plan working dirs accumulate feature caches, model weights, and run logs.
plans/**/_cache/
plans/**/*.npz
plans/**/*.pt
plans/**/*.log
plans/**/babysit_log.txt
plans/**/babysit_state.json

# Cohort / smoke / monitor run logs + transient markers under registry/
registry/scalping_ga_*.log
registry/smoke_*.log
registry/cohort_chain.log
registry/monitor_wake.log
registry/launch_*.log
registry/c2_latest_outdir.txt
registry/_*_ready

# Cohort / smoke / probe output dirs (scoreboards, weights, bet-dumps —
# regenerable; any tracked _summary/_analysis json inside stays tracked)
registry/scalping_ga_*/
registry/smoke_*/
registry/probe_*/
registry/ab_*/
registry/ab_*.log
registry/ab_*.txt
registry/smdc_*/
registry/smdc_*.log
registry/smdc_*.txt
registry/pbt_*/
registry/pbt_*.log

# Stray top-level archive dirs (registry/archive_* is already covered above)
registry_archive_*/
